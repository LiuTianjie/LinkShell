# LinkShell Gateway Environment Variables
# Copy this file to .env and modify as needed

# Gateway listen port
PORT=8787

# Log level: debug, info, warn, error
LOG_LEVEL=info

# ── Official Gateway (Premium) ──────────────────────────────────
# Set AUTH_REQUIRED=true to enable subscription-based access control.
# Self-hosted gateways can leave these unset.

# Enable JWT + subscription validation
AUTH_REQUIRED=false

# Supabase credentials (required when AUTH_REQUIRED=true)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
