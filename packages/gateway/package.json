{
  "name": "@linkshell/gateway",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/gateway/src/index.js",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./embedded": {
      "types": "./src/embedded.ts",
      "import": "./src/embedded.ts",
      "default": "./src/embedded.ts"
    }
  },
  "files": [
    "src",
    "dist",
    "README.md",
    "LICENSE",
    "Dockerfile"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@linkshell/protocol": "workspace:*",
    "zod": "^3.24.3",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@types/ws": "^8.5.14",
    "tsx": "^4.19.3",
    "vitest": "^3.2.1"
  }
}
