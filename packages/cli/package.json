{
  "name": "linkshell-cli",
  "version": "0.2.74",
  "description": "Remote terminal bridge for Claude Code / Codex / Gemini / Copilot — control from your phone",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "linkshell": "dist/cli/src/index.js"
  },
  "files": [
    "dist",
    "src",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "terminal",
    "remote",
    "claude",
    "codex",
    "pty",
    "bridge",
    "mobile",
    "websocket"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LiuTianjie/LinkShell.git"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postinstall": "node scripts/postinstall.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@linkshell/gateway": "^0.2.29",
    "@linkshell/protocol": "^0.2.25",
    "commander": "^13.1.0",
    "node-pty": "^1.0.0",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.1",
    "zod": "^3.24.3"
  },
  "optionalDependencies": {
    "werift": "^0.22.9"
  },
  "devDependencies": {
    "@types/ws": "^8.5.14",
    "tsx": "^4.19.3"
  }
}
