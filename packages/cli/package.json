{
  "name": "linkshell-cli",
  "version": "0.5.14",
  "description": "Remote terminal bridge for Claude Code / Codex / Gemini / Copilot — control from your phone",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "linkshell": "dist/cli/src/index.js"
  },
  "files": [
    "dist",
    "src",
    "scripts",
    "web",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "terminal",
    "remote",
    "claude",
    "codex",
    "pty",
    "bridge",
    "mobile",
    "websocket"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LiuTianjie/LinkShell.git"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-web.mjs",
    "prepack": "pnpm --filter \"...@linkshell/web-dashboard\" build && pnpm run build",
    "postinstall": "node scripts/postinstall.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@linkshell/gateway": "workspace:*",
    "@linkshell/protocol": "workspace:*",
    "commander": "^13.1.0",
    "node-pty": "^1.0.0",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.1",
    "zod": "^3.24.3"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.128",
    "werift": "^0.22.9"
  },
  "devDependencies": {
    "@types/ws": "^8.5.14",
    "tsx": "^4.19.3",
    "vitest": "^3.2.1"
  }
}
