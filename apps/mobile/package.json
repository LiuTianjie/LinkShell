{
  "name": "@linkshell/app",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "start:lan": "expo start --dev-client --host lan",
    "start:expo": "expo start",
    "prebuild-terminal": "node scripts/build-terminal-html.mjs",
    "devbuild": "node scripts/dev-build.mjs",
    "devbuild:ios": "node scripts/dev-build.mjs ios",
    "devbuild:ios:device": "node scripts/dev-build.mjs ios --device",
    "devbuild:ios:device:install": "node scripts/dev-build.mjs ios --device --install-only",
    "devbuild:android": "node scripts/dev-build.mjs android",
    "prod:ios": "node scripts/prod-build.mjs",
    "prod:ios:open": "node scripts/prod-build.mjs --open",
    "prod:ios:quick": "node scripts/prod-build.mjs --skip-prebuild",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@linkshell/protocol": "workspace:*",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-native-voice/voice": "^3.2.4",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/native": "^7.1.6",
    "@xterm/addon-fit": "0.12.0-beta.197",
    "@xterm/addon-web-links": "0.13.0-beta.197",
    "@xterm/xterm": "6.1.0-beta.197",
    "expo": "~54.0.0",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-dev-client": "~6.0.20",
    "expo-glass-effect": "~0.1.9",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "^55.0.16",
    "expo-linking": "~7.0.1",
    "expo-router": "~6.0.23",
    "expo-speech-recognition": "^3.1.2",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "^55.0.5",
    "metro-runtime": "^0.84.2",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "^2.30.1",
    "react-native-reanimated": "^4.3.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-webview": "^13.15.0",
    "react-native-worklets": "^0.8.0"
  },
  "devDependencies": {
    "@rnx-kit/metro-resolver-symlinks": "^0.2.11",
    "@types/react": "^19.1.17",
    "babel-preset-expo": "~54.0.0",
    "typescript": "^5.8.3"
  }
}
