{
  "expo": {
    "name": "LinkShell",
    "slug": "linkshell",
    "version": "1.0.5",
    "scheme": "linkshell",
    "icon": "./assets/adaptive-icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#131314"
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "plugins": [
      [
        "expo-dev-client",
        {
          "launchMode": "most-recent"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow LinkShell to scan pairing QR codes from your terminal."
        }
      ],
      "./plugins/with-live-activity",
      [
        "expo-router",
        {
          "root": "./src/app"
        }
      ],
      "expo-speech-recognition"
    ],
    "web": {
      "bundler": "metro"
    },
    "ios": {
      "bundleIdentifier": "com.bd.linkshell",
      "buildNumber": "17",
      "appleTeamId": "L95PYLFT86",
      "icon": "./assets/adaptive-icon.png",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true,
          "NSExceptionDomains": {
            "115.191.50.117": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSIncludesSubdomains": true
            },
            "69.5.20.235": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSIncludesSubdomains": true
            },
            "18.136.106.162": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSIncludesSubdomains": true
            }
          }
        },
        "ITSAppUsesNonExemptEncryption": false,
        "NSSpeechRecognitionUsageDescription": "LinkShell uses speech recognition for voice input.",
        "NSMicrophoneUsageDescription": "LinkShell needs microphone access for voice input."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#131314"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.bd.linkshell"
    },
    "extra": {
      "eas": {
        "projectId": "1816fe99-767c-43d9-88ef-467468d0bc5f"
      }
    },
    "owner": "nickname4th"
  }
}
