{
  "expo": {
    "name": "LinkShell",
    "slug": "linkshell",
    "scheme": "linkshell",
    "platforms": ["ios", "android", "web"],
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow LinkShell to scan pairing QR codes from your terminal."
        }
      ]
    ],
    "web": {
      "bundler": "metro"
    }
  }
}
